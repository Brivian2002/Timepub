rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email'])
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && (!data.keys().contains('displayName') || (data.displayName is string && data.displayName.size() <= 100))
        && (!data.keys().contains('photoURL') || (data.photoURL is string && data.photoURL.size() <= 1000));
    }

    function isValidConnection(data) {
      return data.keys().hasAll(['userId', 'platform', 'accessToken'])
        && data.userId == request.auth.uid
        && data.platform in ['tiktok', 'youtube', 'facebook']
        && data.accessToken is string && data.accessToken.size() <= 4096;
    }

    function isValidSocialPost(data) {
      return data.keys().hasAll(['userId', 'content', 'platforms', 'status'])
        && data.userId == request.auth.uid
        && data.content is string && data.content.size() <= 10000
        && data.platforms is list && data.platforms.size() > 0 && data.platforms.size() <= 3
        && data.status in ['pending', 'completed', 'failed']
        && (!data.keys().contains('mediaUrls') || (data.mediaUrls is list && data.mediaUrls.size() <= 10));
    }

    // Match patterns
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(incoming());

      match /connections/{platform} {
        allow list, get: if isOwner(userId);
        // Connections are mostly written by the server in our flow, 
        // but if the client needs to update metadata, they can.
        allow create, update: if isOwner(userId) && isValidConnection(incoming());
        allow delete: if isOwner(userId);
      }
    }

    match /posts/{postId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidSocialPost(incoming()) && incoming().userId == request.auth.uid;
      // Posts are generally immutable once status is 'completed'
      allow update: if isSignedIn() 
        && isOwner(existing().userId) 
        && isValidSocialPost(incoming())
        && existing().status != 'completed'
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'results']);
      allow delete: if isOwner(existing().userId);
    }
  }
}
